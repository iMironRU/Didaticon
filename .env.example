# Скопировать в .env и заполнить перед деплоем на VPS.
# cp .env.example .env && nano .env

# ── Домен ──────────────────────────────────────────────────────────────────
EIOS_DOMAIN=eios.example.ru

# ── Univerkon (1С) ─────────────────────────────────────────────────────────
# URL JSON-RPC эндпоинта Univerkon и сервисный токен для межсервисных вызовов.
UNIVERKON_RPC_URL=https://univerkon.example.ru/rpc
UNIVERKON_SERVICE_TOKEN=замените-на-реальный-токен

# ── OIDC (Univerkon как IdP) ───────────────────────────────────────────────
OIDC_ISSUER=https://univerkon.example.ru
OIDC_JWKS_URL=https://univerkon.example.ru/.well-known/jwks.json
OIDC_AUDIENCE=eios-glue

# ── Postgres (срез-2; сейчас используется SQLite) ─────────────────────────
POSTGRES_PASSWORD=замените-на-случайный-пароль
