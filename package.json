{
  "name": "eios",
  "private": true,
  "version": "0.1.0",
  "description": "Студенческий контур ЭИОС поверх Univerkon",
  "workspaces": [
    "packages/*",
    "glue",
    "pwa"
  ],
  "scripts": {
    "build": "npm run build -w @eios/contracts && npm run build -w @eios/glue && npm run build -w @eios/pwa",
    "typecheck": "npm run build -w @eios/contracts && npm run typecheck -w @eios/glue && npm run typecheck -w @eios/pwa",
    "lint": "npm run lint --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "mock": "tsx mock/univerkon.ts",
    "dev:glue": "npm run dev -w @eios/glue",
    "dev:pwa": "npm run dev -w @eios/pwa",
    "prepare": "husky"
  },
  "lint-staged": {
    "pwa/src/**/*.{ts,tsx,js,jsx}": [
      "npm run lint --workspace=@eios/pwa --"
    ]
  },
  "license": "MIT",
  "devDependencies": {
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8"
  }
}
