# Адрес ядра Univerkon (JSON-RPC endpoint)
UNIVERKON_RPC_URL=https://univerkon.example.org/rpc
# Сервисный JWT клея для проводки свидетельств
UNIVERKON_SERVICE_TOKEN=changeme
# OIDC-провайдер Univerkon (для верификации токенов PWA)
OIDC_ISSUER=https://univerkon.example.org/oidc
OIDC_JWKS_URL=https://univerkon.example.org/oidc/jwks
# Хранилище: postgres | sqlite
EIOS_STORE=sqlite
EIOS_SQLITE_PATH=./glue.sqlite
EIOS_PG_URL=
# Роль узла: central | edge (edge = буфер→сверка)
EIOS_ROLE=central
PORT=8080
